# =========================================================================
# Konfigurasi Khusyuk Learn — salin file ini menjadi .env lalu isi nilainya
#   cp server/.env.example server/.env
# Semua punya default yang aman untuk pengembangan, jadi server tetap jalan
# walau .env belum dibuat.
# =========================================================================

# Port & host server
PORT=3000
HOST=0.0.0.0

# --- Login Google (Sign-In) ----------------------------------------------
# Buat OAuth Client ID (tipe: Web application) di Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Tambahkan "Authorized JavaScript origins" sesuai domain kamu, mis:
#   http://localhost:3000  dan  https://app.domainkamu.com
# Lalu tempel Client ID-nya di sini. Kosongkan untuk menonaktifkan tombol Google.
GOOGLE_CLIENT_ID=

# --- Sesi aplikasi --------------------------------------------------------
# Rahasia untuk menandatangani token sesi. Kosongkan -> dibuat otomatis &
# disimpan di server/data/.jwt-secret. Untuk produksi, isi nilai acak panjang.
JWT_SECRET=
SESSION_DAYS=30

# --- Mode dev -------------------------------------------------------------
# true: izinkan login pakai email tanpa Google (untuk testing). Set false di produksi.
DEV_LOGIN=true

# --- Akses awal (seed) ----------------------------------------------------
# Email yang otomatis diberi akses saat database pertama kali dibuat (untuk testing).
# Pisahkan dengan koma.
SEED_EMAILS=demo@khusyuk.test

# --- Admin ----------------------------------------------------------------
# Token untuk membuka /admin dan endpoint /api/admin/*. GANTI untuk produksi!
ADMIN_TOKEN=admin-khusyuk-2026

# --- Webhook pembelian ----------------------------------------------------
# Secret untuk endpoint POST /api/webhook/purchase?secret=XXX. GANTI untuk produksi!
WEBHOOK_SECRET=webhook-khusyuk-2026

# --- Lokasi data (opsional) ----------------------------------------------
# DB_FILE=./server/data/khusyuk.db
# STATIC_DIR=.
